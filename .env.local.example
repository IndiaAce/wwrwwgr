# ── TMDB (The Movie Database) ──────────────────────────────────────────────────
# Get a free API key at: https://www.themoviedb.org/settings/api
# Needed for movie and TV show search + cover art
TMDB_API_KEY=your_tmdb_api_key_here

# ── GitHub (data storage) ──────────────────────────────────────────────────────
# Create a Personal Access Token at: https://github.com/settings/tokens
# Required scopes: repo → contents (read + write)
# This allows the app to read/write data/items.json directly in your repo.
# Every save = a commit. Your data lives in GitHub.
GITHUB_TOKEN=your_github_pat_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=wwrwwgr

# ── Local development only ─────────────────────────────────────────────────────
# When GITHUB_TOKEN is not set, the app reads/writes data/items.json locally.
# No extra setup needed to run locally — just `npm run dev`.
